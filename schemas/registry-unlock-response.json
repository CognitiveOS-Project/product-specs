{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitive-os.org/schemas/registry-unlock-response.json",
  "title": "Registry Unlock Response",
  "description": "Response from POST /v1/patches/{name}/{version}/unlock (200 OK)",
  "type": "object",
  "required": ["status", "name", "version", "message"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok"],
      "description": "Unlock status"
    },
    "name": {
      "type": "string",
      "description": "Package name"
    },
    "version": {
      "type": "string",
      "description": "Version unlocked"
    },
    "message": {
      "type": "string",
      "description": "Human-readable confirmation"
    }
  }
}
