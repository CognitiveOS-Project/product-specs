{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitive-os.org/schemas/registry-package-version.json",
  "title": "Registry Package Version",
  "description": "Version entry in the versions list returned by GET /v1/patches/{name}/versions",
  "type": "object",
  "required": ["version", "status"],
  "properties": {
    "version": {
      "type": "string",
      "description": "SemVer version string"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp of publication"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hex digest of the archive"
    },
    "download_urls": {
      "type": "object",
      "description": "Variant-keyed download URLs",
      "additionalProperties": {
        "type": "string",
        "format": "uri"
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "buggy"],
      "description": "Version status"
    }
  }
}
