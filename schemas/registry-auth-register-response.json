{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognitive-os.org/schemas/registry-auth-register-response.json",
  "title": "Registry Auth Register Response",
  "description": "Response from POST /v1/auth/register (201 Created)",
  "type": "object",
  "required": ["fingerprint", "public_key_type", "registered_at"],
  "properties": {
    "fingerprint": {
      "type": "string",
      "description": "SSH key fingerprint (SHA256:...)"
    },
    "public_key_type": {
      "type": "string",
      "description": "Key type (e.g. ssh-ed25519)"
    },
    "comment": {
      "type": "string",
      "description": "Comment from the public key (e.g. email)"
    },
    "registered_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp of registration"
    }
  }
}
